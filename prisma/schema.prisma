generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String          @db.VarChar(100)
  email        String          @unique @db.VarChar(150)
  password     String          @db.VarChar(255)
  age          Int?            @default(28)
  gender       String?         @default("other") @db.VarChar(20)
  height       Decimal?        @default(175.00) @db.Decimal(5, 2)
  weight       Decimal?        @default(70.00) @db.Decimal(5, 2)
  goal         String?         @default("maintain") @db.VarChar(20)
  budget       Decimal?        @default(150.00) @db.Decimal(10, 2)
  isOnboarded  Boolean?        @default(false) @map("is_onboarded")
  createdAt    DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  stepsTarget  Int?            @default(10000) @map("steps_target")
  sleepTarget  Decimal?        @default(8.00) @map("sleep_target") @db.Decimal(4, 2)
  activities   DailyActivity[]
  exercises    Exercise[]
  groceryItems GroceryItem[]
  meals        Meal[]
  progressLogs Progress[]
  reminders    Reminder[]
  sleepLogs    Sleep[]
  waterIntakes WaterIntake[]

  @@map("users")
}

model DailyActivity {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  steps          Int?     @default(0)
  distance       Decimal? @default(0.00) @db.Decimal(5, 2)
  caloriesBurned Int?     @default(0) @map("calories_burned")
  exerciseTime   Int?     @default(0) @map("exercise_time")
  date           DateTime @db.Date
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, date])
  @@index([userId, date], map: "idx_activity_user_date")
  @@map("daily_activity")
}

model WaterIntake {
  id      String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  glasses Int?     @default(0)
  goal    Int?     @default(12)
  date    DateTime @db.Date
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, date])
  @@index([userId, date], map: "idx_water_user_date")
  @@map("water_intake")
}

model Exercise {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  exerciseName String   @map("exercise_name") @db.VarChar(100)
  duration     Int
  calories     Int
  date         DateTime @db.Date
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, date], map: "idx_exercise_user_date")
  @@map("exercise")
}

model Meal {
  id       String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  mealType String   @map("meal_type") @db.VarChar(50)
  foodName String   @map("food_name") @db.VarChar(150)
  calories Int
  protein  Int
  price    Decimal? @default(0.00) @db.Decimal(6, 2)
  date     DateTime @db.Date
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, mealType, date])
  @@index([userId, date], map: "idx_meals_user_date")
  @@map("meals")
}

model GroceryItem {
  id       String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  week     String  @db.VarChar(50)
  item     String  @db.VarChar(100)
  quantity String  @db.VarChar(50)
  price    Decimal @default(0.00) @db.Decimal(6, 2)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, week], map: "idx_grocery_user_week")
  @@map("grocery_list")
}

model Sleep {
  id      String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  hours   Decimal? @default(0.00) @db.Decimal(4, 2)
  quality String?  @default("good") @db.VarChar(50)
  date    DateTime @db.Date
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, date])
  @@index([userId, date], map: "idx_sleep_user_date")
  @@map("sleep")
}

model Reminder {
  id      String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  type    String   @db.VarChar(50)
  time    DateTime @db.Time(6)
  repeat  String?  @default("daily") @db.VarChar(100)
  enabled Boolean? @default(true)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, type])
  @@index([userId], map: "idx_reminder_user")
  @@map("reminder")
}

model Progress {
  id      String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId  String   @map("user_id") @db.Uuid
  weight  Decimal  @db.Decimal(5, 2)
  bmi     Decimal  @db.Decimal(4, 2)
  bodyFat Decimal? @default(18.5) @map("body_fat") @db.Decimal(4, 2)
  date    DateTime @db.Date
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, date])
  @@index([userId, date], map: "idx_progress_user_date")
  @@map("progress")
}
